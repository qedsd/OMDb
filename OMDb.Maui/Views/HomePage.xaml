<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OMDb.Maui.Views.HomePage"
             xmlns:vm="clr-namespace:OMDb.Maui.ViewModels"
             xmlns:converters="clr-namespace:OMDb.Maui.Converters"
             Title="主页"
             BackgroundColor="{AppThemeBinding Light=#F3F3F3, Dark=#1F1F1F}"
             NavigationCacheMode="Enabled">

    <ContentPage.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToCollapsedConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibleConverter" />
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="刷新"
                     IconImageSource="icon_refresh.png"
                     Command="{Binding RefreshCommand}" />
    </ContentPage.ToolbarItems>

    <!-- 主内容区域 -->
    <ScrollView Grid.Row="0" Margin="10" CornerRadius="8">
        <VerticalStackLayout x:Name="ItemContentPanel"
                             Spacing="10"
                             Padding="10">
            <!-- 动态加载的主页部件将添加到这里 -->
            <!-- 由 VM 动态生成内容 -->
        </VerticalStackLayout>
        <ScrollView.GestureRecognizers>
            <PanGestureRecognizer PanUpdated="OnScrollViewPanUpdated" />
        </ScrollView.GestureRecognizers>
    </ScrollView>
</ContentPage>
