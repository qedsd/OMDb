<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:OMDb.Maui.ViewModels"
             x:Class="OMDb.Maui.Views.ManagementPage"
             Title="管理"
             BackgroundColor="{AppThemeBinding Light=#F3F3F3, Dark=#1F1F1F}">

    <!-- 管理页 - 简化的垂直布局 -->
    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">

            <!-- 仓库管理部分 -->
            <Border Stroke="{AppThemeBinding Light=#CCCCCC, Dark=#555555}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2D2D2D}">
                <VerticalStackLayout Padding="15">
                    <Label Text="仓库管理" FontSize="18" FontAttributes="Bold" Margin="0,0,0,10" />
                    <HorizontalStackLayout Spacing="10">
                        <Button Text="新增" Command="{Binding StorageAddCommand}" />
                        <Button Text="刷新" Command="{Binding StorageRefreshCommand}" />
                    </HorizontalStackLayout>
                    <CollectionView ItemsSource="{Binding EnrtyStorages}"
                                    SelectionMode="None"
                                    Margin="0,10,0,0">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" Span="4"
                                             HorizontalItemSpacing="8" VerticalItemSpacing="8" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeShape="RoundRectangle 8"
                                        BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#3D3D3D}"
                                        HeightRequest="240">
                                    <VerticalStackLayout Padding="10">
                                        <Image Source="{Binding CoverImg}" Aspect="AspectFill" HeightRequest="150" />
                                        <Label Text="{Binding StorageName}" FontSize="14" FontAttributes="Bold" Margin="0,10,0,0" />
                                        <Label Text="{Binding EntryCount, StringFormat='词条数：{0}'}" FontSize="12" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <!-- 标签 (分类) 管理部分 -->
            <Border Stroke="{AppThemeBinding Light=#CCCCCC, Dark=#555555}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2D2D2D}">
                <VerticalStackLayout Padding="15">
                    <Label Text="标签管理 (分类)" FontSize="18" FontAttributes="Bold" Margin="0,0,0,10" />
                    <HorizontalStackLayout Spacing="10">
                        <Button Text="新增" Command="{Binding LabelAddRootCommand}" />
                        <Button Text="刷新" Command="{Binding LabelRefreshCommand}" />
                        <Button Text="样式" Command="{Binding LabelStyleCommand}" />
                    </HorizontalStackLayout>
                    <Label Text="标签内容将显示在这里" Margin="0,10,0,0" TextColor="Gray" />
                </VerticalStackLayout>
            </Border>

            <!-- 标签 (属性) 管理部分 -->
            <Border Stroke="{AppThemeBinding Light=#CCCCCC, Dark=#555555}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2D2D2D}">
                <VerticalStackLayout Padding="15">
                    <Label Text="标签管理 (属性)" FontSize="18" FontAttributes="Bold" Margin="0,0,0,10" />
                    <HorizontalStackLayout Spacing="10">
                        <Button Text="新增" Command="{Binding LabelPropertyAddCommand}" />
                        <Button Text="刷新" Command="{Binding LabelPropertyRefreshCommand}" />
                        <Button Text="导入" Command="{Binding LabelPropertyImportCommand}" />
                        <Button Text="导出" Command="{Binding LabelPropertyExportCommand}" />
                    </HorizontalStackLayout>
                    <Label Text="属性标签内容将显示在这里" Margin="0,10,0,0" TextColor="Gray" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
