<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OMDb.Maui.Views.CollectionsPage"
             xmlns:vm="clr-namespace:OMDb.Maui.ViewModels"
             xmlns:mycontrols="clr-namespace:OMDb.Maui.MyControls"
             Title="片单"
             BackgroundColor="{AppThemeBinding Light=#F3F3F3, Dark=#1F1F1F}"
            >

    <!-- 片单页 -->
    <Grid Margin="24,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Label Text="片单"
                   FontSize="18"
                   VerticalOptions="Center" />

            <HorizontalStackLayout Grid.Column="1"
                                   HorizontalOptions="End"
                                   Spacing="10">
                <!-- 搜索框 -->
                <SearchBar Placeholder="搜索片单..."
                           WidthRequest="300"
                           Text="{Binding SuggestText, Mode=TwoWay}"
                           ItemsSource="{Binding Suggetions, Mode=OneWay}" />

                <!-- 创建片单按钮 -->
                <Button Text="创建片单"
                        ImageSource="icon_add.png"
                        ToolTipProperties.Text="创建片单">
                    <Button.ContextFlyout>
                        <MenuFlyout>
                            <MenuItem Text="确定"
                                      Command="{Binding AddNewCollectionCommand}">
                                <MenuItem.View>
                                    <VerticalStackLayout WidthRequest="300">
                                        <Entry Placeholder="标题"
                                               Text="{Binding NewCollectionTitle, Mode=TwoWay}"
                                               Margin="0,10" />
                                        <Entry Placeholder="描述"
                                               Text="{Binding NewCollectionDesc, Mode=TwoWay}"
                                               Margin="0,10" />
                                        <Button Text="确定"
                                                Command="{Binding AddNewCollectionCommand}"
                                                HorizontalOptions="Center"
                                                Margin="0,10" />
                                    </VerticalStackLayout>
                                </MenuItem.View>
                            </MenuItem>
                        </MenuFlyout>
                    </Button.ContextFlyout>
                </Button>
            </HorizontalStackLayout>
        </Grid>

        <!-- 片单网格列表 -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding EntryCollections}"
                        SelectionMode="None"
                        Margin="0,10,0,0">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical"
                                 Span="3"
                                 HorizontalItemSpacing="8"
                                 VerticalItemSpacing="8" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <mycontrols:EntryCollectionCard Margin="4"
                                                        EntryCollection="{Binding .}">
                            <mycontrols:EntryCollectionCard.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CollectionsViewModel}}, Path=CollectionDetailCommand}"
                                                      CommandParameter="{Binding .}" />
                            </mycontrols:EntryCollectionCard.GestureRecognizers>
                        </mycontrols:EntryCollectionCard>

                        <!-- 右键菜单 -->
                        <Grid.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="编辑"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CollectionsViewModel}}, Path=EditCommand}"
                                                CommandParameter="{Binding .}" />
                                <MenuFlyoutItem Text="删除"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CollectionsViewModel}}, Path=RemoveCommand}"
                                                CommandParameter="{Binding .}" />
                            </MenuFlyout>
                        </Grid.ContextFlyout>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- 全局右键菜单 -->
        <Grid.GestureRecognizers>
            <TapGestureRecognizer NumberOfTapsRequired="2"
                                  Command="{Binding RefreshCommand}" />
        </Grid.GestureRecognizers>
    </Grid>
</ContentPage>
