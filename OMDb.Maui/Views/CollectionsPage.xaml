<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OMDb.Maui.Views.CollectionsPage"
             xmlns:vm="clr-namespace:OMDb.Maui.ViewModels"
             Title="片单"
             BackgroundColor="{AppThemeBinding Light=#F3F3F3, Dark=#1F1F1F}">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <HorizontalStackLayout Grid.Row="0" HorizontalOptions="Fill">
            <Label Text="片单管理" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" />

            <HorizontalStackLayout HorizontalOptions="EndAndExpand" Spacing="10">
                <!-- 搜索框 -->
                <SearchBar Placeholder="搜索片单..."
                           WidthRequest="300"
                           Text="{Binding SuggestText}"
                           SearchCommand="{Binding RefreshCommand}" />

                <!-- 新建片单按钮 -->
                <Button Text="新建"
                        Clicked="NewCollectionButton_Clicked"
                        ImageSource="icon_add.png" />
            </HorizontalStackLayout>
        </HorizontalStackLayout>

        <!-- 片单列表 -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding EntryCollections}"
                        SelectionMode="None"
                        Margin="0,10,0,0">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="3" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="5" HasShadow="False" CornerRadius="8" BackgroundColor="{AppThemeBinding Light=White, Dark=#2D2D2D}">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CollectionsViewModel}}, Path=CollectionDetailCommand}"
                                                  CommandParameter="{Binding .}" />
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Padding="10">
                            <Label Text="{Binding Title}" FontSize="16" FontAttributes="Bold" />
                            <Label Text="{Binding Description}" TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" FontSize="12" Margin="0,5,0,10" />
                            <Label Text="{Binding TotalCount, StringFormat='{0} 个词条'}" FontSize="12" />
                            <Label Text="{Binding WatchedCount, StringFormat='已观看：{0}'}" FontSize="12" TextColor="{AppThemeBinding Light=#0078D4, Dark=#4CC2FF}" />

                            <HorizontalStackLayout HorizontalOptions="End" Spacing="10" Margin="0,10,0,0">
                                <Button Text="编辑" Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CollectionsViewModel}}, Path=EditCommand}" CommandParameter="{Binding .}" />
                                <Button Text="删除" Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CollectionsViewModel}}, Path=RemoveCommand}" CommandParameter="{Binding .}" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
