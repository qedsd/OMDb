<?xml version="1.0" encoding="utf-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       x:Class="OMDb.Maui.AppShell"
       xmlns:views="clr-namespace:OMDb.Maui.Views"
       Title="OMDb"
       FlyoutBehavior="Locked"
       FlyoutWidth="280"
       FlyoutBackgroundColor="{AppThemeBinding Light=#F3F3F3, Dark=#1F1F1F}"
       BackgroundColor="{AppThemeBinding Light=#F3F3F3, Dark=#1F1F1F}">

    <!-- 临时移除自定义 ItemTemplate 以排查问题 -->

    <Shell.FlyoutHeader>
        <Grid Padding="20,24,20,20"
              BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#252525}">
            <VerticalStackLayout Spacing="12">
                <HorizontalStackLayout Spacing="12">
                    <Border WidthRequest="44"
                            HeightRequest="44"
                            StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light=#0078D4, Dark=#2D7DFF}"
                            StrokeShape="RoundRectangle 12">
                        <Image Source="logo_32.png"
                               WidthRequest="24"
                               HeightRequest="24"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout Spacing="2"
                                          VerticalOptions="Center">
                        <Label Text="OMDb"
                               FontAttributes="Bold"
                               FontSize="20"
                               TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}" />
                        <Label Text="Movie Database"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light=#666666, Dark=#B8B8B8}" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>

                <!-- 搜索框 -->
                <Border StrokeShape="RoundRectangle 8"
                        BackgroundColor="{AppThemeBinding Light=#E8E8E8, Dark=#2D2D2D}"
                        HeightRequest="36"
                        Padding="12,0">
                    <HorizontalStackLayout Spacing="8"
                                           VerticalOptions="Center">
                        <Label Text="&#xE721;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="14"
                               TextColor="{AppThemeBinding Light=#666666, Dark=#888888}" />
                        <Label Text="搜索..."
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#666666, Dark=#888888}" />
                    </HorizontalStackLayout>
                </Border>
            </VerticalStackLayout>
        </Grid>
    </Shell.FlyoutHeader>

    <!-- 顶部标题栏 -->
    <Shell.TitleView>
        <Grid BackgroundColor="{AppThemeBinding Light=#F3F3F3, Dark=#202020}"
              HeightRequest="48"
              Padding="16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <HorizontalStackLayout Grid.Column="0"
                                   Spacing="12"
                                   VerticalOptions="Center">
                <ImageButton WidthRequest="36"
                        HeightRequest="36"
                        CornerRadius="18"
                        BackgroundColor="Transparent"
                        BorderWidth="0"
                        Clicked="MenuButton_Clicked">
                    <ImageButton.Source>
                        <FontImageSource Glyph="&#xE700;"
                                        FontFamily="Segoe MDL2 Assets"
                                        Size="16"
                                        Color="{AppThemeBinding Light=#111111, Dark=#FFFFFF}" />
                    </ImageButton.Source>
                </ImageButton>

                <Image Source="logo_32.png"
                       WidthRequest="20"
                       HeightRequest="20"
                       VerticalOptions="Center" />
                <Label Text="OMDb"
                       FontSize="13"
                       FontAttributes="Bold"
                       VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}" />
            </HorizontalStackLayout>
        </Grid>
    </Shell.TitleView>

    <!-- 主页 -->
    <ShellContent Title="主页"
                  ContentTemplate="{DataTemplate views:HomePage}"
                  Route="HomePage">
        <ShellContent.Icon>
            <FontImageSource Glyph="&#xE80F;" FontFamily="Segoe MDL2 Assets" Size="20" />
        </ShellContent.Icon>
    </ShellContent>

    <!-- 分类 -->
    <ShellContent Title="分类"
                  ContentTemplate="{DataTemplate views:ClassificationPage}"
                  Route="ClassificationPage">
        <ShellContent.Icon>
            <FontImageSource Glyph="&#xE8C8;" FontFamily="Segoe MDL2 Assets" Size="20" />
        </ShellContent.Icon>
    </ShellContent>

    <!-- 片单 -->
    <ShellContent Title="片单"
                  ContentTemplate="{DataTemplate views:CollectionsPage}"
                  Route="CollectionsPage">
        <ShellContent.Icon>
            <FontImageSource Glyph="&#xE8A8;" FontFamily="Segoe MDL2 Assets" Size="20" />
        </ShellContent.Icon>
    </ShellContent>

    <!-- 词条 -->
    <ShellContent Title="词条"
                  ContentTemplate="{DataTemplate views:EntryHomePage}"
                  Route="EntryHomePage">
        <ShellContent.Icon>
            <FontImageSource Glyph="&#xE82D;" FontFamily="Segoe MDL2 Assets" Size="20" />
        </ShellContent.Icon>
    </ShellContent>

    <!-- 管理 -->
    <ShellContent Title="管理"
                  ContentTemplate="{DataTemplate views:ManagementPage}"
                  Route="ManagementPage">
        <ShellContent.Icon>
            <FontImageSource Glyph="&#xE7EF;" FontFamily="Segoe MDL2 Assets" Size="20" />
        </ShellContent.Icon>
    </ShellContent>

    <!-- 工具 -->
    <ShellContent Title="工具"
                  ContentTemplate="{DataTemplate views:ToolsPage}"
                  Route="ToolsPage">
        <ShellContent.Icon>
            <FontImageSource Glyph="&#xE7FC;" FontFamily="Segoe MDL2 Assets" Size="20" />
        </ShellContent.Icon>
    </ShellContent>

    <!-- 设置 -->
    <ShellContent Title="设置"
                  ContentTemplate="{DataTemplate views:SettingPage}"
                  Route="SettingPage">
        <ShellContent.Icon>
            <FontImageSource Glyph="&#xE713;" FontFamily="Segoe MDL2 Assets" Size="20" />
        </ShellContent.Icon>
    </ShellContent>

</Shell>
