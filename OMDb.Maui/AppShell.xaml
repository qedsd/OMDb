<?xml version="1.0" encoding="utf-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       x:Class="OMDb.Maui.AppShell"
       xmlns:views="clr-namespace:OMDb.Maui.Views"
       Title="OMDb"
       FlyoutBehavior="Locked"
       FlyoutWidth="280"
       FlyoutBackgroundColor="{AppThemeBinding Light=#F3F3F3, Dark=#1F1F1F}"
       FlyoutForegroundColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"
       BackgroundColor="{AppThemeBinding Light=#F3F3F3, Dark=#1F1F1F}">

    <!-- 自定义导航项模板 - Microsoft Store 风格 -->
    <Shell.ItemTemplate>
        <DataTemplate>
            <Grid HeightRequest="44"
                  Padding="16,0"
                  ColumnDefinitions="Auto,*">
                <Image Source="{Binding Icon}"
                       WidthRequest="20"
                       HeightRequest="20"
                       VerticalOptions="Center" />
                <Label Grid.Column="1"
                       Text="{Binding Title}"
                       FontSize="14"
                       VerticalOptions="Center"
                       Margin="16,0,0,0"
                       TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}" />
            </Grid>
        </DataTemplate>
    </Shell.ItemTemplate>

    <Shell.FlyoutHeader>
        <Grid Padding="20,24,20,20"
              BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#252525}">
            <VerticalStackLayout Spacing="12">
                <HorizontalStackLayout Spacing="12">
                    <Border WidthRequest="44"
                            HeightRequest="44"
                            StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light=#0078D4, Dark=#2D7DFF}"
                            StrokeShape="RoundRectangle 12">
                        <Image Source="logo_32.png"
                               WidthRequest="24"
                               HeightRequest="24"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout Spacing="2"
                                          VerticalOptions="Center">
                        <Label Text="OMDb"
                               FontAttributes="Bold"
                               FontSize="20"
                               TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}" />
                        <Label Text="Movie Database"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light=#666666, Dark=#B8B8B8}" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>

                <!-- 搜索框 -->
                <Border StrokeShape="RoundRectangle 8"
                        BackgroundColor="{AppThemeBinding Light=#E8E8E8, Dark=#2D2D2D}"
                        HeightRequest="36"
                        Padding="12,0">
                    <HorizontalStackLayout Spacing="8"
                                           VerticalOptions="Center">
                        <Label Text="&#xE721;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="14"
                               TextColor="{AppThemeBinding Light=#666666, Dark=#888888}" />
                        <Label Text="搜索..."
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#666666, Dark=#888888}" />
                    </HorizontalStackLayout>
                </Border>
            </VerticalStackLayout>
        </Grid>
    </Shell.FlyoutHeader>

    <!-- 顶部标题栏 -->
    <Shell.TitleView>
        <Grid BackgroundColor="{AppThemeBinding Light=#F3F3F3, Dark=#202020}"
              HeightRequest="48"
              Padding="16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <HorizontalStackLayout Grid.Column="0"
                                   Spacing="12"
                                   VerticalOptions="Center">
                <Button WidthRequest="36"
                        HeightRequest="36"
                        CornerRadius="18"
                        BackgroundColor="Transparent"
                        BorderWidth="0"
                        Clicked="MenuButton_Clicked">
                    <Button.ImageSource>
                        <FontImageSource Glyph="&#xE700;"
                                        FontFamily="Segoe MDL2 Assets"
                                        Size="16"
                                        Color="{AppThemeBinding Light=#111111, Dark=#FFFFFF}" />
                    </Button.ImageSource>
                </Button>

                <Image Source="logo_32.png"
                       WidthRequest="20"
                       HeightRequest="20"
                       VerticalOptions="Center" />
                <Label Text="OMDb"
                       FontSize="13"
                       FontAttributes="Bold"
                       VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}" />
            </HorizontalStackLayout>
        </Grid>
    </Shell.TitleView>

    <!-- 主页 -->
    <ShellContent Title="主页"
                  Icon="icon_home.png"
                  ContentTemplate="{DataTemplate views:HomePage}"
                  Route="HomePage" />

    <!-- 分类 -->
    <ShellContent Title="分类"
                  Icon="icon_category.png"
                  ContentTemplate="{DataTemplate views:ClassificationPage}"
                  Route="ClassificationPage" />

    <!-- 片单 -->
    <ShellContent Title="片单"
                  Icon="icon_collection.png"
                  ContentTemplate="{DataTemplate views:CollectionsPage}"
                  Route="CollectionsPage" />

    <!-- 词条 -->
    <ShellContent Title="词条"
                  Icon="icon_entry.png"
                  ContentTemplate="{DataTemplate views:EntryHomePage}"
                  Route="EntryHomePage" />

    <!-- 管理 -->
    <ShellContent Title="管理"
                  Icon="icon_manage.png"
                  ContentTemplate="{DataTemplate views:ManagementPage}"
                  Route="ManagementPage" />

    <!-- 工具 -->
    <ShellContent Title="工具"
                  Icon="icon_tool.png"
                  ContentTemplate="{DataTemplate views:ToolsPage}"
                  Route="ToolsPage" />

    <!-- 设置 -->
    <ShellContent Title="设置"
                  Icon="icon_setting.png"
                  ContentTemplate="{DataTemplate views:SettingPage}"
                  Route="SettingPage" />

</Shell>
