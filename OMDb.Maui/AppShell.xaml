<?xml version="1.0" encoding="utf-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       x:Class="OMDb.Maui.AppShell"
       xmlns:views="clr-namespace:OMDb.Maui.Views"
       Title="OMDb"
       FlyoutBehavior="Flyout"
       FlyoutWidth="280"
       FlyoutBackgroundColor="{AppThemeBinding Light=#F3F3F3, Dark=#1F1F1F}"
       BackgroundColor="{AppThemeBinding Light=#F3F3F3, Dark=#1F1F1F}">

    <!-- Microsoft Store 风格左侧导航栏 -->
    <Shell.FlyoutHeader>
        <Grid WidthRequest="280"
              BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#252525}">
            <VerticalStackLayout Spacing="8"
                                 Padding="12,16">
                <!-- Logo 区域 -->
                <HorizontalStackLayout Spacing="12"
                                       HeightRequest="40"
                                       VerticalOptions="Center">
                    <Border WidthRequest="32"
                            HeightRequest="32"
                            StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light=#0078D4, Dark=#2D7DFF}"
                            StrokeShape="RoundRectangle 8">
                        <Image Source="logo_32.png"
                               WidthRequest="20"
                               HeightRequest="20"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                    <Label Text="OMDb"
                           FontAttributes="Bold"
                           FontSize="18"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}" />
                </HorizontalStackLayout>

                <!-- 搜索框 -->
                <Border StrokeShape="RoundRectangle 6"
                        BackgroundColor="{AppThemeBinding Light=#E8E8E8, Dark=#2D2D2D}"
                        HeightRequest="32"
                        Padding="10,0">
                    <HorizontalStackLayout Spacing="8"
                                           VerticalOptions="Center">
                        <Label Text="&#xE721;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="14"
                               TextColor="{AppThemeBinding Light=#666666, Dark=#888888}" />
                        <Label Text="搜索..."
                               FontSize="12"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light=#666666, Dark=#888888}" />
                    </HorizontalStackLayout>
                </Border>
            </VerticalStackLayout>
        </Grid>
    </Shell.FlyoutHeader>

    <!-- 自定义导航项模板 - Microsoft Store 风格 -->
    <Shell.ItemTemplate>
        <DataTemplate x:DataType="ShellContent">
            <Grid HeightRequest="48"
                  Padding="16,0"
                  BackgroundColor="Transparent">
                <Border x:Name="SelectionIndicator"
                        WidthRequest="3"
                        HeightRequest="16"
                        HorizontalOptions="Start"
                        VerticalOptions="Center"
                        BackgroundColor="Transparent"
                        StrokeShape="RoundRectangle 1.5"
                        IsVisible="{Binding IsCurrent, Source={RelativeSource AncestorType={x:Type Shell}}}">
                    <BackgroundBehavior>
                        <BackgroundColor Value="{AppThemeBinding Light=#0078D4, Dark=#2D7DFF}" />
                    </BackgroundBehavior>
                </Border>
                <HorizontalStackLayout Spacing="12"
                                       VerticalOptions="Center">
                    <Image Source="{Binding Icon}"
                           WidthRequest="20"
                           HeightRequest="20"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                    <Label Text="{Binding Title}"
                           FontSize="14"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}" />
                </HorizontalStackLayout>
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="Selected">
                                <VisualState.Setters>
                                    <Setter TargetName="SelectionIndicator"
                                            Property="BackgroundColor"
                                            Value="{AppThemeBinding Light=#0078D4, Dark=#2D7DFF}" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="PointerOver">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor"
                                            Value="{AppThemeBinding Light=#F0F0F0, Dark=#2D2D2D}" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>
            </Grid>
        </DataTemplate>
    </Shell.ItemTemplate>

    <!-- 主页 -->
    <ShellContent Title="主页"
                  ContentTemplate="{DataTemplate views:HomePage}"
                  Route="HomePage">
        <ShellContent.Icon>
            <FontImageSource Glyph="&#xE80F;" FontFamily="Segoe MDL2 Assets" Size="20" />
        </ShellContent.Icon>
    </ShellContent>

    <!-- 分类 -->
    <ShellContent Title="分类"
                  ContentTemplate="{DataTemplate views:ClassificationPage}"
                  Route="ClassificationPage">
        <ShellContent.Icon>
            <FontImageSource Glyph="&#xE8C8;" FontFamily="Segoe MDL2 Assets" Size="20" />
        </ShellContent.Icon>
    </ShellContent>

    <!-- 片单 -->
    <ShellContent Title="片单"
                  ContentTemplate="{DataTemplate views:CollectionsPage}"
                  Route="CollectionsPage">
        <ShellContent.Icon>
            <FontImageSource Glyph="&#xE8A8;" FontFamily="Segoe MDL2 Assets" Size="20" />
        </ShellContent.Icon>
    </ShellContent>

    <!-- 词条 -->
    <ShellContent Title="词条"
                  ContentTemplate="{DataTemplate views:EntryHomePage}"
                  Route="EntryHomePage">
        <ShellContent.Icon>
            <FontImageSource Glyph="&#xE82D;" FontFamily="Segoe MDL2 Assets" Size="20" />
        </ShellContent.Icon>
    </ShellContent>

    <!-- 管理 -->
    <ShellContent Title="管理"
                  ContentTemplate="{DataTemplate views:ManagementPage}"
                  Route="ManagementPage">
        <ShellContent.Icon>
            <FontImageSource Glyph="&#xE7EF;" FontFamily="Segoe MDL2 Assets" Size="20" />
        </ShellContent.Icon>
    </ShellContent>

    <!-- 工具 -->
    <ShellContent Title="工具"
                  ContentTemplate="{DataTemplate views:ToolsPage}"
                  Route="ToolsPage">
        <ShellContent.Icon>
            <FontImageSource Glyph="&#xE7FC;" FontFamily="Segoe MDL2 Assets" Size="20" />
        </ShellContent.Icon>
    </ShellContent>

    <!-- 设置 -->
    <ShellContent Title="设置"
                  ContentTemplate="{DataTemplate views:SettingPage}"
                  Route="SettingPage">
        <ShellContent.Icon>
            <FontImageSource Glyph="&#xE713;" FontFamily="Segoe MDL2 Assets" Size="20" />
        </ShellContent.Icon>
    </ShellContent>

</Shell>
